{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "萤火笔记",
  "version": "0.0.4",
  "identifier": "com.firefly",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "萤火笔记",
        "width": 1100,
        "height": 700
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": [
          "SimpChinese"
        ],
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": true
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "tray": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  }
}